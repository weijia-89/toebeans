#!/usr/bin/env bash
# toebeans pre-commit hook — enforces AGENTS.md vibe-dangerous review gate.
#
# RULES
# -----
# 1. If any staged file touches a vibe-dangerous path (see PATTERNS below):
#    a. `.codeit/calibration.jsonl` MUST also be staged.
#    b. The staged diff of `.codeit/calibration.jsonl` MUST add at least one new JSONL entry
#       (a line beginning with `{` and ending with `}`).
# 2. If a staged file modifies `androidApp/src/main/AndroidManifest.xml`, AND the diff adds
#    a NEW `uses-permission` line, that line's value MUST already be on the AGENTS.md
#    allowlist (the hook does NOT enforce this — that is the human reviewer's job — but
#    it WARNS prominently).
# 3. If a staged file modifies `AGENTS.md` or `CLAUDE.md`, BOTH must be staged and the
#    fitness-function `scripts/agents_claude_parity.sh` must pass.
#
# BYPASS
# ------
# `git commit --no-verify` bypasses this hook. Do not do that for vibe-dangerous changes.
#
# INSTALL
# -------
# This file lives at scripts/git-hooks/pre-commit (tracked).
# Install by running: bash scripts/install-git-hooks.sh
# which sets `git config core.hooksPath scripts/git-hooks`.

set -euo pipefail

# Bold red for errors so they cannot be missed in a busy terminal.
RED='\033[1;31m'
YEL='\033[1;33m'
GRN='\033[1;32m'
NC='\033[0m'

# ---------------------------------------------------------------------------
# Rule 0 — Optional branch protection. Off by default (solo workflow). Enable
# by setting TOEBEANS_PROTECT_MAIN=1 in your shell (or in a per-clone env file).
# When enabled, refuses commits made directly on `main`. Override per-commit
# with TOEBEANS_ALLOW_MAIN=1 (for the rare unavoidable case).
# ---------------------------------------------------------------------------
if [[ "${TOEBEANS_PROTECT_MAIN:-0}" == "1" && "${TOEBEANS_ALLOW_MAIN:-0}" != "1" ]]; then
    BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")
    if [[ "$BRANCH" == "main" ]]; then
        echo -e "${RED}BLOCKED${NC} — TOEBEANS_PROTECT_MAIN=1 is set and you are committing on main."
        echo "  Create a feature branch (\`git checkout -b feat/...\`) or set"
        echo "  TOEBEANS_ALLOW_MAIN=1 for this single commit."
        exit 1
    fi
fi

# ---------------------------------------------------------------------------
# Rule -1 (runs before everything else) — Secrets scan on the STAGED DIFF.
# High-precision regexes for common credential formats. Lower false-positive
# rate than a tool like gitleaks but also fewer rules. If gitleaks is installed
# locally we additionally invoke it.
# ---------------------------------------------------------------------------
STAGED_DIFF=$(git diff --cached --no-color || true)
if [[ -n "$STAGED_DIFF" ]]; then
    # Aggregate well-known credential patterns. Each is high-precision.
    SECRET_PATTERNS=(
        'AKIA[0-9A-Z]{16}'                       # AWS Access Key ID
        'gh[pousr]_[A-Za-z0-9]{36,}'             # GitHub PAT / OAuth / Refresh
        'xox[bpars]-[A-Za-z0-9-]{10,72}'         # Slack tokens
        '-----BEGIN [A-Z ]*PRIVATE KEY-----'     # PEM private keys
        'sk-[A-Za-z0-9]{32,}'                    # OpenAI-style secret
        'glpat-[A-Za-z0-9_-]{20,}'               # GitLab PAT
    )
    PATTERN_REGEX=$(printf '%s|' "${SECRET_PATTERNS[@]}")
    PATTERN_REGEX="(${PATTERN_REGEX%|})"
    if HITS=$(echo "$STAGED_DIFF" | grep -E "$PATTERN_REGEX" | head -5); [[ -n "$HITS" ]]; then
        echo -e "${RED}BLOCKED${NC} — potential secret detected in staged diff:"
        echo "$HITS" | sed 's/^/  /' | cut -c1-120
        echo ""
        echo "  If this is a false positive, rephrase the snippet (e.g. use a placeholder)."
        echo "  To bypass for a legitimate test fixture, \`git commit --no-verify\` (but note: the"
        echo "  CI secrets-scan job will catch it again on push)."
        exit 1
    fi
fi

# ===== em-dash check =====
# Per the em-dash iron rule (Wei voice MEMORY[39c0f94f]), U+2014 is banned
# from toebeans documentation. This check runs BEFORE the vibe-dangerous
# early-exit below so it fires on every commit that stages a doc file, not
# only on vibe-dangerous commits (most doc edits live in docs/ and ADRs,
# which are not in the vibe-dangerous regex). The CI fitness function at
# scripts/test_no_em_dash_in_docs.sh runs the same logic against the full
# tree on every push.
#
# Scope here: staged-only via `git diff --cached`. Allow-list opt-out:
# EMDASH-ALLOWED in the first 5 lines of the file. The fitness function
# script reads the working-tree copy of each file, which is fine for
# normal "edit then add then commit" flows; the CI gate catches any
# divergence between index and working tree.
EMDASH_STAGED=$(git diff --cached --name-only --diff-filter=ACM \
    | grep -E '\.(md|txt)$' || true)
if [[ -n "$EMDASH_STAGED" ]]; then
    EMDASH_BYTES=$(printf '\xe2\x80\x94')
    EMDASH_HITS=""
    while IFS= read -r f; do
        [[ -z "$f" ]] && continue
        [[ ! -f "$f" ]] && continue
        # Allow-list opt-out: EMDASH-ALLOWED in first 5 lines.
        if head -n 5 "$f" 2>/dev/null \
            | LC_ALL=C grep -qF -- 'EMDASH-ALLOWED'; then
            continue
        fi
        if hits=$(LC_ALL=C grep -nF --binary-files=without-match \
                -- "$EMDASH_BYTES" "$f" 2>/dev/null); then
            EMDASH_HITS+="${f}:"$'\n'"${hits}"$'\n'
        fi
    done <<< "$EMDASH_STAGED"
    if [[ -n "$EMDASH_HITS" ]]; then
        echo -e "${RED}BLOCKED${NC} em-dash (U+2014) detected in staged docs:"
        echo "$EMDASH_HITS" | sed 's/^/  /'
        echo ""
        echo "  Per the em-dash iron rule (Wei voice MEMORY[39c0f94f]),"
        echo "  em-dashes are banned from toebeans documentation. Repair:"
        echo "    1. Replace each with a colon, period, comma, or parens."
        echo "    2. Rewrite the sentence to drop the parenthetical aside."
        echo "    3. If the file legitimately needs to discuss em-dashes,"
        echo "       add the literal token EMDASH-ALLOWED to the first 5"
        echo "       lines and name the exception in the calibration entry."
        echo ""
        echo "  See scripts/test_no_em_dash_in_docs.sh for the CI gate."
        exit 1
    fi
fi

# Vibe-dangerous path patterns (regex, anchored to repo root).
# KEEP IN SYNC with scripts/ci-vibe-dangerous-check.sh PATTERNS array.
VIBE_DANGEROUS=(
    # Medication-critical code surfaces
    '^shared/src/commonMain/kotlin/app/toebeans/core/scheduler/'
    '^shared/src/commonMain/kotlin/app/toebeans/core/backup/'
    '^shared/src/jvmMain/kotlin/app/toebeans/core/backup/'
    '^shared/src/androidMain/kotlin/app/toebeans/core/backup/'
    '^shared/src/commonTest/kotlin/app/toebeans/core/scheduler/'
    '^shared/src/commonTest/kotlin/app/toebeans/core/backup/'
    '^shared/src/jvmTest/kotlin/app/toebeans/core/backup/'
    '^androidApp/src/main/kotlin/app/toebeans/android/notifications/'
    '^androidApp/src/test/kotlin/app/toebeans/android/notifications/'
    # Trust-critical config + manifests + deps
    '^shared/src/commonMain/sqldelight/'
    '^androidApp/src/main/AndroidManifest\.xml$'
    '^.*/build\.gradle\.kts$'
    '^gradle/libs\.versions\.toml$'
    # Meta: the enforcement infrastructure itself.
    # Modifying these CAN silently disable other gates, so changes here ARE
    # vibe-dangerous and require a calibration entry. Yes, this means modifying
    # the hook to add a new pattern is itself enforced by the hook.
    '^scripts/git-hooks/'
    '^scripts/ci-vibe-dangerous-check\.sh$'
    '^scripts/test_.*\.sh$'
    '^scripts/agents_claude_parity\.sh$'
    '^\.github/workflows/'
    '^AGENTS\.md$'
    '^CLAUDE\.md$'
)

STAGED=$(git diff --cached --name-only --diff-filter=ACMR)
if [[ -z "$STAGED" ]]; then
    exit 0
fi

# Build a single regex.
PATTERN=$(printf '%s\n' "${VIBE_DANGEROUS[@]}" | paste -sd '|' -)

VIBE_HITS=$(echo "$STAGED" | grep -E "$PATTERN" || true)

if [[ -z "$VIBE_HITS" ]]; then
    # No vibe-dangerous paths touched. Allow.
    exit 0
fi

echo -e "${YEL}toebeans pre-commit:${NC} vibe-dangerous paths touched:"
echo "$VIBE_HITS" | sed 's/^/  /'
echo ""

# Rule 1a: calibration.jsonl must also be staged.
if ! echo "$STAGED" | grep -qx '\.codeit/calibration\.jsonl'; then
    echo -e "${RED}BLOCKED${NC} — vibe-dangerous change without a calibration entry."
    echo "  Per AGENTS.md § Confidence-score rule, every change to a vibe-dangerous"
    echo "  surface must be scored and logged to .codeit/calibration.jsonl."
    echo ""
    echo "  Append a JSONL line like:"
    cat <<'EXAMPLE'
    {"date":"2026-05-15","change":"<short summary>","tier":"vibe-dangerous","score":95,"components":{"code_read":15,"test_verif":18,"halluc":15,"bug_class":11,"adversarial":9,"reversibility":8,"doc":8,"blast":7,"threat_model":5},"reviewer":"<name>","notes":"<optional>"}
EXAMPLE
    echo "  then \`git add .codeit/calibration.jsonl\` and re-commit."
    echo ""
    exit 1
fi

# Rule 1b: calibration.jsonl diff must add at least one new JSONL entry line.
ADDED=$(git diff --cached --no-color -- .codeit/calibration.jsonl \
    | grep -E '^\+\{.*\}$' || true)
if [[ -z "$ADDED" ]]; then
    echo -e "${RED}BLOCKED${NC} — calibration.jsonl is staged but no new entry was added."
    echo "  Make sure the staged diff includes a new line of the form {...}."
    exit 1
fi

# Rule 2: warn on new uses-permission lines.
if echo "$STAGED" | grep -qx 'androidApp/src/main/AndroidManifest\.xml'; then
    NEW_PERMS=$(git diff --cached --no-color -- androidApp/src/main/AndroidManifest.xml \
        | grep -E '^\+.*uses-permission' || true)
    if [[ -n "$NEW_PERMS" ]]; then
        echo -e "${YEL}WARN${NC} — AndroidManifest.xml adds uses-permission lines:"
        echo "$NEW_PERMS" | sed 's/^/  /'
        echo "  Confirm each is on the AGENTS.md allowlist. The CI fitness"
        echo "  function 'scripts/test_permission_allowlist.sh' will block merge"
        echo "  if any is not."
        echo ""
    fi
fi

# Rule 3: AGENTS.md / CLAUDE.md parity.
TOUCHES_AGENTS=$(echo "$STAGED" | grep -E '^(AGENTS|CLAUDE)\.md$' || true)
if [[ -n "$TOUCHES_AGENTS" ]]; then
    if ! echo "$STAGED" | grep -qx 'AGENTS\.md' || ! echo "$STAGED" | grep -qx 'CLAUDE\.md'; then
        echo -e "${RED}BLOCKED${NC} — AGENTS.md and CLAUDE.md must be staged together."
        exit 1
    fi
    if [[ -x scripts/agents_claude_parity.sh ]]; then
        if ! bash scripts/agents_claude_parity.sh . >/dev/null 2>&1; then
            echo -e "${RED}BLOCKED${NC} — AGENTS.md / CLAUDE.md parity check failed."
            echo "  Run: bash scripts/agents_claude_parity.sh ."
            exit 1
        fi
    fi
fi

echo -e "${GRN}toebeans pre-commit: OK${NC} — vibe-dangerous change with calibration entry."
exit 0
