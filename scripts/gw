#!/usr/bin/env bash
# Thin wrapper around ./gradlew with three properties:
#   1. Default --offline (no network resolution) UNLESS GW_ONLINE=1.
#   2. Default --console=plain --no-watch-fs only if we detect we are NOT in a TTY
#      (e.g. inside CI or a piped agent invocation). Local TTY use gets the rich console.
#   3. Streams stderr+stdout through `awk` to flush each line as it arrives — eliminates
#      the "frozen for 60s, then a wall of output" effect that makes agent runs look hung.
#
# Use anywhere ./gradlew would work:
#   bash scripts/gw :shared:jvmTest
#   GW_ONLINE=1 bash scripts/gw build   # forces fresh dependency resolution

set -euo pipefail

REPO_ROOT=$(cd "$(dirname "$0")/.." && pwd)
cd "$REPO_ROOT"

# ---------------------------------------------------------------------------
# JDK auto-detection. On macOS the system `java` is often missing or wrong-
# version. We probe well-known Homebrew + JEnv + system locations in priority
# order. The user can override with TOEBEANS_JAVA_HOME or a pre-set JAVA_HOME.
# ---------------------------------------------------------------------------
detect_java_home() {
    # 1. Explicit override always wins.
    if [[ -n "${TOEBEANS_JAVA_HOME:-}" ]]; then
        echo "$TOEBEANS_JAVA_HOME"
        return 0
    fi
    # 2. Pre-set JAVA_HOME, but only if it actually points to a runnable JDK.
    if [[ -n "${JAVA_HOME:-}" && -x "$JAVA_HOME/bin/java" ]]; then
        echo "$JAVA_HOME"
        return 0
    fi
    # 3. Common Homebrew locations. We want JDK 17 specifically (matches
    #    sourceCompatibility in shared/build.gradle.kts).
    local candidates=(
        /usr/local/opt/openjdk@17/libexec/openjdk.jdk/Contents/Home
        /opt/homebrew/opt/openjdk@17/libexec/openjdk.jdk/Contents/Home
        /Library/Java/JavaVirtualMachines/temurin-17.jdk/Contents/Home
        /Library/Java/JavaVirtualMachines/zulu-17.jdk/Contents/Home
        /Library/Java/JavaVirtualMachines/openjdk-17.jdk/Contents/Home
    )
    for c in "${candidates[@]}"; do
        if [[ -x "$c/bin/java" ]]; then
            echo "$c"
            return 0
        fi
    done
    # 4. macOS java_home helper as last resort. Returns the system "best" JDK,
    #    which may be the wrong version — we filter by 17 explicitly.
    if command -v /usr/libexec/java_home >/dev/null 2>&1; then
        local jh
        if jh=$(/usr/libexec/java_home -v 17 2>/dev/null) && [[ -x "$jh/bin/java" ]]; then
            echo "$jh"
            return 0
        fi
    fi
    return 1
}

if ! JAVA_HOME=$(detect_java_home); then
    cat >&2 <<'EOF'
scripts/gw: BLOCKED — no JDK 17 found on this machine.

The project targets JDK 17 (see shared/build.gradle.kts sourceCompatibility).
Install one of:
  brew install openjdk@17                  # most common on macOS
  brew install --cask temurin@17           # Eclipse Adoptium

…or set TOEBEANS_JAVA_HOME explicitly:
  export TOEBEANS_JAVA_HOME=/path/to/jdk-17/Contents/Home

After installing, run again. This script will NOT silently fall back to a
different JDK version because that produces confusing compilation errors.
EOF
    exit 127
fi
export JAVA_HOME
export PATH="$JAVA_HOME/bin:$PATH"

ARGS=("$@")

# Online-by-default ONLY if explicitly opted in. Otherwise --offline.
if [[ "${GW_ONLINE:-0}" != "1" ]]; then
    ARGS=(--offline "${ARGS[@]}")
fi

# Agent / CI / non-TTY detection. tty -s returns 1 outside a TTY.
if ! tty -s; then
    ARGS=(--console=plain --no-watch-fs --quiet "${ARGS[@]}")
fi

# Line-buffer stdout so an agent watching the pipe sees progress in real time.
# stdbuf is gnu coreutils; on macOS install via `brew install coreutils` (gstdbuf).
# Fall back to unbuffered Python if neither is available.
if command -v stdbuf >/dev/null 2>&1; then
    exec stdbuf -oL -eL ./gradlew "${ARGS[@]}"
elif command -v gstdbuf >/dev/null 2>&1; then
    exec gstdbuf -oL -eL ./gradlew "${ARGS[@]}"
elif command -v python3 >/dev/null 2>&1; then
    exec python3 -u -c '
import os, sys, subprocess
p = subprocess.Popen(sys.argv[1:], stdout=sys.stdout, stderr=sys.stderr, bufsize=1)
sys.exit(p.wait())
' ./gradlew "${ARGS[@]}"
else
    exec ./gradlew "${ARGS[@]}"
fi
