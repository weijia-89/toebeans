# --- toebeans .gitignore ---

# JVM / Gradle
.gradle/
build/
out/
!**/src/**/build/
!**/src/**/out/
local.properties
*.hprof

# Kotlin / KMP
.kotlin/
kotlin-js-store/

# IDE
.idea/
*.iml
*.ipr
*.iws
.vscode/
*.swp
*.swo

# macOS / system
.DS_Store
Thumbs.db

# Android
*.apk
*.aab
*.ap_
*.dex
captures/
.externalNativeBuild/
.cxx/
release/

# Keystores (NEVER commit)
*.jks
*.keystore
keystore.properties

# Coverage / reports
*.exec
*.coverage
jacoco.exec

# codeit state. calibration.jsonl IS tracked (vibe-dangerous audit log per
# AGENTS.md confidence-score rule). Only ephemeral aborts/sessions are ignored.
.codeit/abort-*/

# Local toolchain pins (sdkman/asdf etc. may go elsewhere)
.tool-versions.local

# Backup / ad-hoc
*.bak
*.orig

# Anything matching localonly convention (per workspace policy)
localonly/

# Git worktrees for parallel-agent work
.worktrees/
